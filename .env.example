# ── Local development ─────────────────────────────────────────────────────────

# Required: random secret key for Flask sessions
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret-key

# Dev mode: enables debug + non-HTTPS cookies
FLASK_ENV=development

# SQLite path (local dev only — not used on Netlify)
# DB_PATH=data/certs.db


# ── Netlify / Production ──────────────────────────────────────────────────────

# PostgreSQL connection string from Neon (https://neon.tech — free tier)
# Required when deploying to Netlify. Leave blank for local SQLite dev.
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require


# ── Legacy (one-time migration only) ─────────────────────────────────────────
# These seed the first admin account from the old password-only setup.
# Leave blank for new installs — use: python scripts/create_admin.py
# ADMIN_PASSWORD_HASH=pbkdf2:sha256:...
# ADMIN_USERNAME=admin
